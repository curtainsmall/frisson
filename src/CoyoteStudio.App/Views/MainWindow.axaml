
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CoyoteStudio.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CoyoteStudio.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Coyote Studio">

	

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

	<Grid ColumnDefinitions="Auto, *, 250" Background="{DynamicResource MainBg}">
    
    <Border Grid.Column="0" Background="{DynamicResource SideBg}" 
            BorderBrush="{DynamicResource GoldBrush}" BorderThickness="0,0,1,0"
            Width="150" Padding="15">
        <StackPanel Spacing="10">
            <TextBlock Text="DASHBOARD" Foreground="{DynamicResource GoldBrush}" 
                       FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
            <Button Content="OVERVIEW" Foreground="{DynamicResource PrimaryText}" 
                    Background="Transparent" BorderBrush="{DynamicResource GoldLow}" 
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
            <Button Content="NETWORK" Foreground="{DynamicResource PrimaryText}" 
                    Background="Transparent" HorizontalAlignment="Stretch" />
        </StackPanel>
    </Border>

    <Border Grid.Column="1" Padding="20">
        <StackPanel>
            <TextBlock Text="System Status" FontSize="24" 
                       Foreground="{DynamicResource GoldBrush}" FontWeight="SemiBold"/>
            <Separator Background="{DynamicResource GoldLow}" Margin="0,10" Height="1"/>
            <TextBlock Text="Backend core running..." Foreground="{DynamicResource SecondaryText}"/>
        </StackPanel>
    </Border>

    <Grid Grid.Column="2" Background="{DynamicResource SideBg}" RowDefinitions="Auto, *">
        <Border Grid.Row="0" Padding="15" BorderBrush="{DynamicResource GoldLow}" BorderThickness="0,0,0,1">
            <TextBlock Text="ACTIVE CLIENTS" Foreground="{DynamicResource GoldBrush}" 
                       FontSize="10" FontWeight="Bold"/>
        </Border>
        <ListBox Grid.Row="1" ItemsSource="{Binding ConnectedClients}" Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="5">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource GoldBrush}"/> 
                        <TextBlock Text="{Binding ClientName}" Foreground="{DynamicResource PrimaryText}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Grid>

</Window>
