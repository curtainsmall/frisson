<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CoyoteStudio.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CoyoteStudio.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Coyote Studio"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="{DynamicResource Black}">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Width" Value ="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0.5" />
            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="{DynamicResource Black}" />
        </Style>

        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GoldBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn.selected /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource GoldBrush}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Border BorderThickness="4" Background="Transparent">
        <Grid RowDefinitions="Auto, *" Background="Transparent">
            <Border
            Grid.Row="0"
            Height="32"
            Background="Transparent"
            PointerPressed="OnTitleBarPointerPressed">
                <TextBlock Text="Coyote Studio" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" />
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Background="Transparent">
                <!-- Left Navigation Panel -->
                <Grid Grid.Column="0" Width="60" Background="Transparent">
                    <StackPanel Spacing="10" Margin="5">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsMixerSelected}"
                                ToolTip.Tip="Mixer"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Mixer}">
                            <i:Icon Value="fa-solid fa-sliders" />
                        </Button>
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsWavesSelected}"
                                ToolTip.Tip="Wave Generator"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Waves}">
                            <i:Icon Value="fa-solid fa-wave-square" />
                        </Button>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom" Spacing="5" Margin="5">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsSettingsSelected}"
                                ToolTip.Tip="Settings"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Settings}">
                            <i:Icon Value="fa-solid fa-gear" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Right Content Area -->
                <Border Grid.Column="1" Padding="20" Background="Transparent">
                    <Panel>
                    <!-- Mixer Page -->
                    <Grid IsVisible="{Binding IsMixerSelected}" ColumnDefinitions="*, 300">
                        <!-- Left: Placeholder -->
                        <Border Grid.Column="0" Padding="20" Background="Transparent">
                            <TextBlock Text="Mixer Controls (Placeholder)" 
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        
                        <!-- Right: Connected Clients -->
                        <Border Grid.Column="1" Background="Transparent" BorderBrush="{DynamicResource GoldLow}" BorderThickness="1,0,0,0">
                            <Grid RowDefinitions="Auto, *, Auto">
                                <Border Grid.Row="0" Padding="15" BorderBrush="{DynamicResource GoldLow}" BorderThickness="0,0,0,1">
                                    <TextBlock Text="CONNECTED CLIENTS" Foreground="{DynamicResource GoldBrush}"
                                               FontSize="10" FontWeight="Bold" />
                                </Border>
                                
                                <ScrollViewer Grid.Row="1">
                                    <ItemsControl ItemsSource="{Binding ConnectedClients}" Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Black}" 
                                                        BorderBrush="{DynamicResource GoldLow}"
                                                        BorderThickness="1"
                                                        CornerRadius="8" 
                                                        Padding="12" 
                                                        Margin="0,0,0,10">
                                                    <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                                                        <TextBlock Grid.Row="0" 
                                                                   Text="{Binding ClientType}" 
                                                                   Foreground="{DynamicResource GoldBrush}"
                                                                   FontWeight="SemiBold" FontSize="12"/>
                                                        <TextBlock Grid.Row="1" 
                                                                   Text="{Binding ClientId}" 
                                                                   Foreground="{DynamicResource SecondaryText}"
                                                                   FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                                            <Ellipse Width="6" Height="6" 
                                                                     Fill="{Binding StatusColor}" />
                                                            <TextBlock Text="{Binding Status}" 
                                                                       Foreground="{DynamicResource SecondaryText}"
                                                                       FontSize="10"/>
                                                        </StackPanel>
                                                        <!-- Client Panel Buttons -->
                                                        <Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                                                            <Button Grid.Column="0" 
                                                                    HorizontalAlignment="Left"
                                                                    Background="Transparent"
                                                                    Padding="4">
                                                                <i:Icon Value="fa-solid fa-ellipsis" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                                                            </Button>
                                                            <Button Grid.Column="1" 
                                                                    HorizontalAlignment="Right"
                                                                    Background="Transparent"
                                                                    Padding="4">
                                                                <i:Icon Value="fa-solid fa-stop" FontSize="14" Foreground="#FF4444"/>
                                                            </Button>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <!-- Waves Page -->
                    <Grid IsVisible="{Binding IsWavesSelected}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <i:Icon Value="fa-solid fa-wave-square" FontSize="48" Foreground="{DynamicResource GoldBrush}" Margin="0,0,0,20"/>
                            <TextBlock Text="Wave Generator" FontSize="24"
                                       Foreground="{DynamicResource GoldBrush}" FontWeight="SemiBold" />
                            <Separator Background="{DynamicResource GoldLow}" Margin="0,10" Width="200" Height="1" />
                            <TextBlock Text="Waveform visualization placeholder..." 
                                       Foreground="{DynamicResource SecondaryText}" />
                        </StackPanel>
                    </Grid>
                    
                    <!-- Settings Page -->
                    <Grid IsVisible="{Binding IsSettingsSelected}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <i:Icon Value="fa-solid fa-gear" FontSize="48" Foreground="{DynamicResource GoldBrush}" Margin="0,0,0,20"/>
                            <TextBlock Text="Settings" FontSize="24"
                                       Foreground="{DynamicResource GoldBrush}" FontWeight="SemiBold" />
                            <Separator Background="{DynamicResource GoldLow}" Margin="0,10" Width="200" Height="1" />
                            <TextBlock Text="Application settings placeholder..." 
                                       Foreground="{DynamicResource SecondaryText}" />
                        </StackPanel>
                    </Grid>
                    </Panel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>