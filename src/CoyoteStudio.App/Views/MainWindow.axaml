<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CoyoteStudio.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:loc="using:CoyoteStudio.App.MarkupExtensions"
        xmlns:services="using:CoyoteStudio.App.Services"
        xmlns:converters="using:CoyoteStudio.App.Converters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CoyoteStudio.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{loc:Loc AppTitle}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="{DynamicResource Black}"
        MinWidth="900"
        MinHeight="600">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Width" Value ="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0.5" />
            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="{DynamicResource Black}" />
        </Style>

        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn.selected /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Border BorderThickness="4" Background="Transparent">
        <Grid RowDefinitions="Auto, *" Background="Transparent">
            <Border
            Grid.Row="0"
            Height="32"
            Background="Transparent"
            PointerPressed="OnTitleBarPointerPressed">
                <TextBlock Text="{loc:Loc AppTitle}" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0" />
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Background="Transparent">
                <!-- Left Navigation Panel -->
                <Grid Grid.Column="0" Width="60" Background="Transparent">
                    <StackPanel Spacing="10" Margin="5">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsMixerSelected}"
                                ToolTip.Tip="{loc:Loc NavMixer}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Mixer}">
                            <i:Icon Value="fa-solid fa-sliders" />
                        </Button>
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsWavesSelected}"
                                ToolTip.Tip="{loc:Loc NavWaveGenerator}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Waves}">
                            <i:Icon Value="fa-solid fa-wave-square" />
                        </Button>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom" Spacing="5" Margin="5">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsSettingsSelected}"
                                ToolTip.Tip="{loc:Loc NavSettings}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Settings}">
                            <i:Icon Value="fa-solid fa-gear" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Center Content Area -->
                <Border Grid.Column="1" Padding="20" Background="Transparent">
                    <Panel>
                    <!-- Mixer Page -->
                    <Grid IsVisible="{Binding IsMixerSelected}" RowDefinitions="Auto,Auto,Auto,*" Margin="10">
                        <!-- Channel A & B Controls -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,20">
                            <!-- Channel A -->
                            <Border Grid.Column="0" Background="{DynamicResource SurfaceDark}" CornerRadius="12" Padding="15" Margin="0,0,10,0">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                    <!-- Channel Label -->
                                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="{DynamicResource AccentBrush}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="{loc:Loc ChannelA}" Foreground="{DynamicResource Black}" FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                    <!-- Value Display -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="0" FontSize="48" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" FontWeight="Light"/>
                                    
                                    <!-- Minus Button -->
                                    <Button Grid.Row="2" Grid.Column="0" Width="50" Height="50" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="5" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <TextBlock Text="−" FontSize="28" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <!-- Progress Info -->
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="80/100" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    <!-- Plus Button -->
                                    <Button Grid.Row="2" Grid.Column="2" Width="50" Height="50" Background="{DynamicResource AccentBrush}" CornerRadius="10" Margin="5" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <TextBlock Text="+" FontSize="28" Foreground="{DynamicResource Black}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- Channel B -->
                            <Border Grid.Column="1" Background="{DynamicResource SurfaceDark}" CornerRadius="12" Padding="15" Margin="10,0,0,0">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                                    <!-- Channel Label -->
                                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="{DynamicResource AccentBrush}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <TextBlock Text="{loc:Loc ChannelB}" Foreground="{DynamicResource Black}" FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                    <!-- Value Display -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="0" FontSize="48" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" FontWeight="Light"/>
                                    
                                    <!-- Minus Button -->
                                    <Button Grid.Row="2" Grid.Column="0" Width="50" Height="50" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="5" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <TextBlock Text="−" FontSize="28" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <!-- Progress Info -->
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="80/100" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                                    <!-- Plus Button -->
                                    <Button Grid.Row="2" Grid.Column="2" Width="50" Height="50" Background="{DynamicResource AccentBrush}" CornerRadius="10" Margin="5" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <TextBlock Text="+" FontSize="28" Foreground="{DynamicResource Black}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                        
                        <!-- Play Button & Settings -->
                        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,15">
                            <Button Grid.Column="0" Width="50" Height="50" Background="{DynamicResource SurfaceLight}" CornerRadius="10" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <i:Icon Value="fa-solid fa-play" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                            </Button>
                            <Button Grid.Column="1" Height="50" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="10,0" Padding="15,0" BorderThickness="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <TextBlock Text="{loc:Loc SetAccessoryMode}" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Button>
                            <Button Grid.Column="2" Width="50" Height="50" Background="{DynamicResource SurfaceLight}" CornerRadius="10" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <i:Icon Value="fa-solid fa-rotate-right" FontSize="20" Foreground="{DynamicResource AccentBrush}"/>
                            </Button>
                        </Grid>
                        
                        <!-- AB Sync Label -->
                        <Button Grid.Row="2" Height="50" Background="{DynamicResource AccentBrush}" CornerRadius="8" Padding="12,0" Margin="0,0,0,15" HorizontalAlignment="Stretch" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                            <TextBlock Text="{loc:Loc ABChannelSync}" Foreground="{DynamicResource Black}" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                        </Button>
                        
                        <!-- Waveform Selection Area -->
                        <Grid Grid.Row="3" RowDefinitions="Auto,*,Auto">
                            <!-- Section Header -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="☰" Foreground="{DynamicResource AccentBrush}" FontSize="16"/>
                                    <TextBlock Text="{loc:Loc CustomCombination}" Foreground="{DynamicResource AccentBrush}" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                                
                            </Grid>
                            
                            <!-- Waveform Grid -->
                            <ScrollViewer Grid.Row="1">
                                <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto,Auto">
                                    <!-- Row 1 -->
                                    <Button Grid.Row="0" Grid.Column="0" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="2" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="3" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    
                                    <!-- Row 2 -->
                                    <Button Grid.Row="1" Grid.Column="0" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="2" Background="{DynamicResource AccentBrush}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource Black}"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="3" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    
                                    <!-- Row 3 -->
                                    <Button Grid.Row="2" Grid.Column="0" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="1" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="2" Background="{DynamicResource AccentBrush}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource Black}"/>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="3" Background="{DynamicResource AccentBrush}" CornerRadius="10" Width="70" Height="70" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                        <i:Icon Value="fa-solid fa-wave-square" FontSize="24" Foreground="{DynamicResource Black}"/>
                                    </Button>
                                </Grid>
                            </ScrollViewer>
                            
                            <!-- Bottom Control Bar -->
                            <Grid Grid.Row="2" ColumnDefinitions="*,*,*,*,*" Margin="0,15,0,0">
                                <Button Grid.Column="0" Width="70" Height="70" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <i:Icon Value="fa-solid fa-repeat" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                </Button>
                                <Button Grid.Column="1" Width="70" Height="70" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <i:Icon Value="fa-solid fa-pause" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                </Button>
                                <Button Grid.Column="2" Width="70" Height="70" Background="{DynamicResource AccentBrush}" CornerRadius="10" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <i:Icon Value="fa-solid fa-play" FontSize="24" Foreground="{DynamicResource Black}"/>
                                </Button>
                                <Button Grid.Column="3" Width="70" Height="70" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <i:Icon Value="fa-solid fa-stopwatch" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                </Button>
                                <Button Grid.Column="4" Width="70" Height="70" Background="{DynamicResource SurfaceLight}" CornerRadius="10" Margin="4" BorderThickness="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <i:Icon Value="fa-solid fa-list" FontSize="24" Foreground="{DynamicResource AccentBrush}"/>
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>
                    
                    <!-- Waves Page -->
                    <Grid IsVisible="{Binding IsWavesSelected}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <i:Icon Value="fa-solid fa-wave-square" FontSize="48" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,20"/>
                            <TextBlock Text="{loc:Loc NavWaveGenerator}" FontSize="24"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                            <Separator Background="{DynamicResource AccentMuted}" Margin="0,10" Width="200" Height="1" />
                            <TextBlock Text="{loc:Loc WaveformPlaceholder}" 
                                       Foreground="{DynamicResource SecondaryText}" />
                        </StackPanel>
                    </Grid>
                    
                    <!-- Settings Page -->
                    <Grid IsVisible="{Binding IsSettingsSelected}" RowDefinitions="Auto,*">
                        <!-- Settings Header -->
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20">
                            <i:Icon Value="fa-solid fa-gear" FontSize="48" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,20"/>
                            <TextBlock Text="{loc:Loc NavSettings}" FontSize="24"
                                       Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                            <Separator Background="{DynamicResource AccentMuted}" Margin="0,10" Width="200" Height="1" />
                        </StackPanel>
                        
                        <!-- Settings Content -->
                        <Border Grid.Row="1" MaxWidth="400" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*">
                                <!-- Language Selection -->
                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                           Text="{loc:Loc Language}" 
                                           Foreground="{DynamicResource PrimaryText}"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="0,0,20,0"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedLanguage}"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource SurfaceLight}"
                                          Foreground="{DynamicResource PrimaryText}"
                                          BorderBrush="{DynamicResource AccentMuted}"
                                          CornerRadius="8"
                                          Padding="10,5">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </Grid>
                        </Border>
                    </Grid>
                    </Panel>
                </Border>
                
                <!-- Right: Collapsible Connected Clients Panel -->
                <Grid Grid.Column="2" Width="{Binding IsClientPanelExpanded, Converter={x:Static converters:BoolToWidthConverter.Instance}, ConverterParameter=300}">
                    <Grid RowDefinitions="Auto, *">
                        <!-- Toggle Button Header -->
                        <Border Grid.Row="0" Padding="10" BorderBrush="{DynamicResource AccentMuted}" BorderThickness="0,0,0,1">
                            <Button Background="Transparent" 
                                    BorderThickness="0"
                                    Padding="5"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleClientPanelCommand}">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="{loc:Loc ConnectedClients}" 
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="10" 
                                               FontWeight="Bold"
                                               IsVisible="{Binding IsClientPanelExpanded}"/>
                                    <i:Icon Grid.Column="1" 
                                            Value="{Binding IsClientPanelExpanded, Converter={x:Static converters:BoolToIconConverter.Instance}, ConverterParameter='fa-solid fa-chevron-right;fa-solid fa-chevron-left'}" 
                                            FontSize="12" 
                                            Foreground="{DynamicResource AccentBrush}"/>
                                </Grid>
                            </Button>
                        </Border>
                        
                        <!-- Client List -->
                        <ScrollViewer Grid.Row="1" IsVisible="{Binding IsClientPanelExpanded}">
                            <ItemsControl ItemsSource="{Binding ConnectedClients}" Margin="10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Black}" 
                                                BorderBrush="{DynamicResource AccentMuted}"
                                                BorderThickness="1"
                                                CornerRadius="8" 
                                                Padding="12" 
                                                Margin="0,0,0,10">
                                            <Grid RowDefinitions="Auto, Auto, Auto, Auto">
                                                <TextBlock Grid.Row="0" 
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           FontWeight="SemiBold" FontSize="12">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{x:Static services:LocMultiConverter.Instance}">
                                                            <Binding Path="ClientTypeKey"/>
                                                            <Binding Source="{x:Static services:LocalizationService.Instance}" Path="CurrentCulture"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Grid.Row="1" 
                                                           Text="{Binding ClientId}" 
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="5" Margin="0,5,0,0">
                                                    <Ellipse Width="6" Height="6" 
                                                             Fill="{Binding StatusColor}" />
                                                    <TextBlock Foreground="{DynamicResource SecondaryText}"
                                                               FontSize="10">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{x:Static services:LocMultiConverter.Instance}">
                                                                <Binding Path="StatusKey"/>
                                                                <Binding Source="{x:Static services:LocalizationService.Instance}" Path="CurrentCulture"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Client Panel Buttons -->
                                                <Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                                                    <Button Grid.Column="0" 
                                                            HorizontalAlignment="Left"
                                                            Background="Transparent"
                                                            Padding="4">
                                                        <i:Icon Value="fa-solid fa-ellipsis" FontSize="14" Foreground="{DynamicResource SecondaryText}"/>
                                                        <Button.Flyout>
                                                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                                                <MenuItem Header="{loc:Loc MenuItem1}" />
                                                                <MenuItem Header="{loc:Loc MenuItem2}" />
                                                                <MenuItem Header="{loc:Loc MenuItem3}" />
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                    <Button Grid.Column="1" 
                                                            HorizontalAlignment="Right"
                                                            Background="Transparent"
                                                            Padding="4">
                                                        <i:Icon Value="fa-solid fa-stop" FontSize="14" Foreground="#FF4444"/>
                                                    </Button>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>