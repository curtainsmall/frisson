<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CoyoteStudio.App.App"
             xmlns:local="using:CoyoteStudio.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- 主背景色 - 深灰黑色 -->
                    <SolidColorBrush x:Key="Black" Color="#1a1a1a" />
                    <SolidColorBrush x:Key="SurfaceDark" Color="#2d2d2d" />
                    <SolidColorBrush x:Key="SurfaceLight" Color="#3a3a3a" />

                    <!-- 暖黄色主题色 (Warm Yellow Theme) -->
                    <SolidColorBrush x:Key="AccentBrush" Color="#e8d4a2" />
                    <SolidColorBrush x:Key="AccentLight" Color="#f5e6c8" />
                    <SolidColorBrush x:Key="AccentDark" Color="#c9b082" />
                    <SolidColorBrush x:Key="AccentMuted" Color="#5a4d30" />

                    <!-- 文字颜色 -->
                    <SolidColorBrush x:Key="PrimaryText" Color="#f5f5f5" />
                    <SolidColorBrush x:Key="SecondaryText" Color="#a0a0a0" />
                    <SolidColorBrush x:Key="DisabledText" Color="#666666" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>