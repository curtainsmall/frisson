<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="CoyoteStudio.App.App"
             xmlns:local="using:CoyoteStudio.App"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="MainBg" Color="#1a1a1a" />
                    <SolidColorBrush x:Key="SideBg" Color="#111111" />
                    <SolidColorBrush x:Key="PanelBorder" Color="#333333" />
                    
                    <SolidColorBrush x:Key="GoldBrush" Color="#d4af37" />
                    <SolidColorBrush x:Key="GoldLow" Color="#4d3d12" />
                    
                    <SolidColorBrush x:Key="PrimaryText" Color="#e5e5e5" />
                    <SolidColorBrush x:Key="SecondaryText" Color="#888888" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>