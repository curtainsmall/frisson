<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Frisson.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:loc="using:Frisson.App.MarkupExtensions"
        xmlns:services="using:Frisson.App.Services"
        xmlns:converters="using:Frisson.App.Converters"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Frisson.App.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Frisson.ico"
        Title="{loc:Loc AppTitle}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"

        Background="{DynamicResource Black}"
        MinWidth="900"
        MinHeight="600">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Width" Value ="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0.5" />
            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="{DynamicResource Black}" />
        </Style>

        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn.selected /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn-text">
            <Setter Property="Width" Value="155" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="12,0" />

            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Button.nav-btn-text:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Button.nav-btn-text.selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.selected">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
        </Style>

    </Window.Styles>

    <Border BorderThickness="4" Background="Transparent" Padding="8,0,8,8">
        <Grid RowDefinitions="Auto, *" Background="Transparent">
            <!-- Title Bar -->
            <Border
                Grid.Row="0"
                Background="{DynamicResource Black}"
                Padding="10,8,175,8"
                PointerPressed="OnTitleBarPointerPressed">
                <TextBlock Text="{loc:Loc AppTitle}" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" FontSize="14" />
            </Border>

            <!-- Main 3-Column Layout -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Background="Transparent">

                <!-- ===== Column 0: Nav Bar ===== -->
                <Border Grid.Column="0" Width="175" Background="Transparent"
                        BorderBrush="{DynamicResource AccentMuted}" BorderThickness="0,0,1,0">
                    <Grid Background="Transparent">
                    <!-- Top: Page nav buttons -->
                    <StackPanel Spacing="6" Margin="0,8" VerticalAlignment="Top">
                        <Button Classes="nav-btn-text"
                                Classes.selected="{Binding IsControlDeskSelected}"
                                Content="{loc:Loc NavControlDesk}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.ControlDesk}" />
                        <Button Classes="nav-btn-text"
                                Classes.selected="{Binding IsControlSourcesSelected}"
                                Content="{loc:Loc NavControlSources}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.ControlSources}" />
                    </StackPanel>

                    <!-- Bottom: Settings -->
                    <Button Classes="nav-btn-text"
                            Classes.selected="{Binding IsSettingsSelected}"
                            Content="{loc:Loc NavSettings}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="{x:Static vm:NavPage.Settings}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,12" />
                    </Grid>
                </Border>

                <!-- ===== Column 1: Center Content ===== -->
                <Border Grid.Column="1" Padding="16" Background="Transparent">
                    <Panel>
                        <!-- Control Desk Page -->
                        <Grid IsVisible="{Binding IsControlDeskSelected}">
                            <TextBlock Text="{loc:Loc LocalControlPlaceholder}" FontSize="14"
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>

                        <!-- Control Sources Page -->
                        <Grid IsVisible="{Binding IsControlSourcesSelected}" ColumnDefinitions="260, 8, *">
                            <!-- Left: Source Card List -->
                            <Grid Grid.Column="0" RowDefinitions="Auto, *">
                                <TextBlock Grid.Row="0" Text="{loc:Loc NavControlSources}"
                                           Foreground="{DynamicResource PrimaryText}"
                                           FontWeight="SemiBold" FontSize="14"
                                           Margin="4,0,0,8" />
                                <Border Grid.Row="1"
                                        Background="{DynamicResource Black}"
                                        BorderBrush="{DynamicResource AccentMuted}"
                                        BorderThickness="0,2,0,0"
                                        CornerRadius="0"
                                        Padding="8">
                                    <Panel>
                                        <ScrollViewer>
                                            <ItemsControl ItemsSource="{Binding SourceCards}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource SurfaceDark}"
                                                                CornerRadius="6"
                                                                Padding="12"
                                                                Margin="0,0,0,4"
                                                                PointerPressed="OnAgentCardPointerPressed">
                                                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                                                                <i:Icon Grid.Column="0" Grid.RowSpan="2"
                                                                        Value="fa-solid fa-diagram-project"
                                                                        FontSize="16"
                                                                        Foreground="{DynamicResource AccentBrush}"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,10,0" />
                                                                <TextBlock Grid.Column="1" Grid.Row="0"
                                                                           Text="{Binding AgentKindLabel}"
                                                                           Foreground="{DynamicResource AccentBrush}"
                                                                           FontWeight="SemiBold" FontSize="12" />
                                                                <TextBlock Grid.Column="1" Grid.Row="1"
                                                                           Text="{Binding AgentId, StringFormat='{}{0}'}"
                                                                           Foreground="{DynamicResource SecondaryText}"
                                                                           FontSize="10" TextTrimming="CharacterEllipsis" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <TextBlock Text="{loc:Loc NoAgent}"
                                                   IsVisible="{Binding !HasAgents}"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Panel>
                                </Border>
                            </Grid>

                            <!-- Right: Detail Panel (placeholder) -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource Black}"
                                    Padding="20">
                                <TextBlock Text="{loc:Loc SourceDetails}"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontSize="14"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Opacity="0.5" />
                            </Border>
                        </Grid>

                        <!-- Settings Page -->
                        <Grid IsVisible="{Binding IsSettingsSelected}" RowDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20">
                                <i:Icon Value="fa-solid fa-gear" FontSize="48" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,20" />
                                <TextBlock Text="{loc:Loc NavSettings}" FontSize="24"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                <Separator Background="{DynamicResource AccentMuted}" Margin="0,10" Width="200" Height="1" />
                            </StackPanel>

                            <ScrollViewer Grid.Row="1" MaxWidth="400" HorizontalAlignment="Center" Margin="20">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="20" ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{loc:Loc Language}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="14"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              HorizontalAlignment="Stretch"
                                              Background="{DynamicResource SurfaceLight}"
                                              Foreground="{DynamicResource PrimaryText}"
                                              BorderBrush="{DynamicResource AccentMuted}"
                                              CornerRadius="8"
                                              Padding="10,5">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{loc:Loc LogLabel}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="14"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Row="1" Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="{loc:Loc LogOpen}"
                                                Width="80"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                CornerRadius="10"
                                                Background="{DynamicResource SurfaceLight}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                BorderBrush="{DynamicResource AccentMuted}"
                                                Command="{Binding ShowLogWindowCommand}" />
                                        <Button Content="{loc:Loc LogClearLogs}"
                                                Width="100"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                CornerRadius="10"
                                                Background="{DynamicResource SurfaceLight}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                BorderBrush="{DynamicResource AccentMuted}"
                                                Command="{Binding ClearLogsCommand}" />
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Panel>
                </Border>

                <!-- ===== Column 2: Global Right Device Panel ===== -->
                <Border Grid.Column="2" Width="260"
                        Background="{DynamicResource Black}"
                        BorderBrush="{DynamicResource AccentMuted}"
                        BorderThickness="2,0,0,0"
                        Padding="12">
                    <Grid RowDefinitions="Auto, Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="4,8,4,4">
                            <TextBlock Grid.Column="0" Text="{loc:Loc DevicesTitle}"
                                       Foreground="{DynamicResource PrimaryText}"
                                       FontWeight="SemiBold" FontSize="14"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="+"
                                    Width="22" Height="22"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource SecondaryText}"
                                    ToolTip.Tip="{loc:Loc AddDevice}"
                                    Command="{Binding ShowQrCodeWindowCommand}" />
                        </Grid>
                        <Separator Grid.Row="1"
                                   Background="{DynamicResource AccentMuted}"
                                   Margin="4,0,4,8"
                                   Height="1" />
                        <Border Grid.Row="2"
                                Background="Transparent"
                                CornerRadius="0"
                                Padding="4">
                            <Panel>
                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding DeviceCards}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SurfaceDark}"
                                                        CornerRadius="6"
                                                        Padding="10"
                                                        Margin="0,0,0,6"
                                                        Classes.selected="{Binding IsSelected}"
                                                        PointerPressed="OnAgentCardPointerPressed">
                                                    <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                                                        <i:Icon Grid.Column="0" Grid.RowSpan="2"
                                                                Value="fa-solid fa-microchip"
                                                                FontSize="16"
                                                                Foreground="{DynamicResource AccentBrush}"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,10,0" />
                                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                                   Text="{Binding AgentKindLabel}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontWeight="SemiBold" FontSize="12" />
                                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                                   Text="{Binding AgentId, StringFormat='{}{0}'}"
                                                                   Foreground="{DynamicResource SecondaryText}"
                                                                   FontSize="10" TextTrimming="CharacterEllipsis" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="{loc:Loc NoAgent}"
                                           IsVisible="{Binding !HasAgents}"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Panel>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
