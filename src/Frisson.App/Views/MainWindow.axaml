<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Frisson.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:loc="using:Frisson.App.MarkupExtensions"
        xmlns:services="using:Frisson.App.Services"
        xmlns:converters="using:Frisson.App.Converters"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Frisson.App.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Frisson.ico"
        Title="{loc:Loc AppTitle}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"

        Background="{DynamicResource Black}"
        MinWidth="900"
        MinHeight="600">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Width" Value ="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0.5" />
            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="{DynamicResource Black}" />
        </Style>

        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn.selected /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Border.selected">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
        to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Border BorderThickness="4" Background="Transparent" Padding="8,0,8,8">
        <Grid RowDefinitions="Auto, *" Background="Transparent">
            <Border
                Grid.Row="0"
                Background="{DynamicResource Black}"
                Padding="10,8,140,8"
                PointerPressed="OnTitleBarPointerPressed">
                <TextBlock Text="{loc:Loc AppTitle}" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" FontSize="14" />
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="Auto, *" Background="Transparent">
                <!-- Left Navigation Panel -->
                <Grid Grid.Column="0" Width="60" Background="Transparent">
                    <StackPanel Spacing="10" Margin="5">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsConnectionsSelected}"
                                ToolTip.Tip="{loc:Loc NavConnections}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Connections}">
                            <i:Icon Value="fa-solid fa-diagram-project" />
                        </Button>
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsLocalControlSelected}"
                                ToolTip.Tip="{loc:Loc NavLocalControl}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.LocalControl}">
                            <i:Icon Value="fa-solid fa-sliders" />
                        </Button>
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom" Spacing="5" Margin="5">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsSettingsSelected}"
                                ToolTip.Tip="{loc:Loc NavSettings}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Settings}">
                            <i:Icon Value="fa-solid fa-gear" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Center Content Area -->
                <Border Grid.Column="1" Padding="20" Background="Transparent">
                    <Panel>
                        <!-- Connections Page -->
                        <Grid IsVisible="{Binding IsConnectionsSelected}" ColumnDefinitions="300, 8, *">
                            <!-- Left: Agent Card List -->
                            <Grid Grid.Column="0" RowDefinitions="Auto, *">
                                <!-- List Title -->
                                <TextBlock Grid.Row="0" Text="{loc:Loc AgentsListTitle}"
                                           Foreground="{DynamicResource PrimaryText}"
                                           FontWeight="SemiBold" FontSize="14"
                                           Margin="4,0,0,8" />
                                <Border Grid.Row="1"
                                        Background="{DynamicResource Black}"
                                        BorderBrush="{DynamicResource AccentMuted}"
                                        BorderThickness="0,2,0,0"
                                        CornerRadius="0"
                                        Padding="8">
                                    <Panel>
                                    <ScrollViewer>
                                        <ItemsControl ItemsSource="{Binding AgentCards}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource SurfaceDark}"
                                                            CornerRadius="6"
                                                            Padding="12"
                                                            Margin="0,0,0,4"
                                                    Tag="{Binding AgentId}"
                                                    Classes.selected="{Binding IsSelected}"
                                                    Classes.device="{Binding IsDevice}"
                                                    Classes.control="{Binding IsControl}"
                                                    PointerPressed="OnAgentCardPointerPressed"
                                                    DragDrop.Drop="OnAgentCardDrop"
                                                    DragDrop.DragOver="OnAgentCardDragOver"
                                                    DragDrop.AllowDrop="{Binding IsControl}">
                                                <Border.RenderTransform>
                                                    <TranslateTransform X="{Binding IndentLevel, Converter={x:Static converters:IndentToMarginConverter.Instance}}" />
                                                </Border.RenderTransform>
                                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto">
                                                    <!-- Kind icon -->
                                                    <i:Icon Grid.Column="0" Grid.RowSpan="2"
                                                            Value="fa-solid fa-microchip"
                                                            FontSize="16"
                                                            Foreground="{DynamicResource AccentBrush}"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0" />
                                                    <!-- Kind label -->
                                                    <TextBlock Grid.Column="1" Grid.Row="0"
                                                               Text="{Binding AgentKindLabel}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontWeight="SemiBold" FontSize="12" />
                                                    <!-- Agent ID -->
                                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                                               Text="{Binding AgentId, StringFormat='{}{0}'}"
                                                               Foreground="{DynamicResource SecondaryText}"
                                                               FontSize="10" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <!-- Empty state -->
                                    <TextBlock Text="{loc:Loc NoAgent}"
                                               IsVisible="{Binding !HasAgents}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="14"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Panel>
                                </Border>
                            </Grid>

                            <!-- Right: Agent Detail Panel (placeholder) -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource Black}"
                                    Padding="20" />
                        </Grid>

                        <!-- Local Control Page -->
                        <Grid IsVisible="{Binding IsLocalControlSelected}">
                            <TextBlock Text="{loc:Loc LocalControlPlaceholder}" FontSize="24"
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Grid>

                        <!-- Settings Page -->
                        <Grid IsVisible="{Binding IsSettingsSelected}" RowDefinitions="Auto,*,Auto">
                            <!-- Settings Header -->
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20">
                                <i:Icon Value="fa-solid fa-gear" FontSize="48" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,20" />
                                <TextBlock Text="{loc:Loc NavSettings}" FontSize="24"
                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                <Separator Background="{DynamicResource AccentMuted}" Margin="0,10" Width="200" Height="1" />
                            </StackPanel>

                            <!-- Settings Content -->
                            <ScrollViewer Grid.Row="1" MaxWidth="400" HorizontalAlignment="Center" Margin="20">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="20">
                                    <!-- Language Selection -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{loc:Loc Language}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,20,0" />
                                    <ComboBox Grid.Row="0" Grid.Column="1"
                                              ItemsSource="{Binding AvailableLanguages}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              HorizontalAlignment="Stretch"
                                              Background="{DynamicResource SurfaceLight}"
                                              Foreground="{DynamicResource PrimaryText}"
                                              BorderBrush="{DynamicResource AccentMuted}"
                                              CornerRadius="8"
                                              Padding="10,5">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <!-- Log -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{loc:Loc LogLabel}"
                                               Foreground="{DynamicResource PrimaryText}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,20,0" />
                                    <StackPanel Grid.Row="1" Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8">
                                        <Button Content="{loc:Loc LogOpen}"
                                                Width="80"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                CornerRadius="10"
                                                Background="{DynamicResource SurfaceLight}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                BorderBrush="{DynamicResource AccentMuted}"
                                                Command="{Binding ShowLogWindowCommand}" />
                                        <Button Content="{loc:Loc LogClearLogs}"
                                                Width="100"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                CornerRadius="10"
                                                Background="{DynamicResource SurfaceLight}"
                                                Foreground="{DynamicResource PrimaryText}"
                                                BorderBrush="{DynamicResource AccentMuted}"
                                                Command="{Binding ClearLogsCommand}" />
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Panel>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>