<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Frisson.Desktop.App"
             xmlns:local="using:Frisson.Desktop"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- дё»иғҢжҷҜиүІ - ж·ұзҒ°й»‘иүІ -->
                    <SolidColorBrush x:Key="Black" Color="#1a1a1a" />
                    <SolidColorBrush x:Key="SurfaceDark" Color="#2d2d2d" />
                    <SolidColorBrush x:Key="SurfaceLight" Color="#3a3a3a" />

                    <!-- жҡ–й»„иүІдё»йўҳиүІ (Warm Yellow Theme) -->
                    <SolidColorBrush x:Key="AccentBrush" Color="#e8d4a2" />
                    <SolidColorBrush x:Key="AccentLight" Color="#f5e6c8" />
                    <SolidColorBrush x:Key="AccentDark" Color="#c9b082" />
                    <SolidColorBrush x:Key="AccentMuted" Color="#5a4d30" />

                    <!-- ж–Үеӯ—йўңиүІ -->
                    <SolidColorBrush x:Key="PrimaryText" Color="#f5f5f5" />
                    <SolidColorBrush x:Key="SecondaryText" Color="#a0a0a0" />
                    <SolidColorBrush x:Key="DisabledText" Color="#666666" />

                    <!-- ж Үйўҳж ҸжҢүй’?hover/pressed еҺӢдҪҺдә®еәҰ -->
                    <SolidColorBrush x:Key="CaptionButtonBackground" Color="#25FFFFFF" />
                    <SolidColorBrush x:Key="CaptionButtonBorderBrush" Color="#15FFFFFF" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>