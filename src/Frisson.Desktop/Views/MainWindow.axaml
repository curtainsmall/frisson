<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Frisson.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:loc="using:Frisson.Desktop.MarkupExtensions"
        xmlns:services="using:Frisson.Desktop.Services"
        xmlns:converters="using:Frisson.Desktop.Converters"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="Frisson.Desktop.Views.MainWindow"
        x:Name="Root"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Frisson.ico"
        Title="{loc:Loc AppTitle}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"

        Background="{DynamicResource Black}"
        MinWidth="900"
        MinHeight="600">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Width" Value ="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />

            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="{DynamicResource Black}" />
        </Style>

        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn.selected /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style Selector="Button.nav-btn-text">
            <Setter Property="Width" Value="155" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="12,0" />

            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />

            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Button.nav-btn-text:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Button.nav-btn-text.selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style Selector="Border.selected">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
        </Style>

        <!-- Strength control buttons (+/−) -->
        <Style Selector="Border.strength-btn">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
        </Style>
        <Style Selector="Border.strength-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
        </Style>

        <!-- Strength value number (scrollable) — fixed-size rounded square highlight -->
        <Style Selector="Border.strength-value-bg">
            <Setter Property="Width" Value="140" />
            <Setter Property="Height" Value="90" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ToolTip.Tip" Value="{loc:Loc ControlDeskScrollTip}" />
        </Style>
        <Style Selector="Border.strength-value-bg:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentMuted}" />
        </Style>

        <!-- Settings section nav buttons -->
        <Style Selector="Button.section-btn">
            <Setter Property="Height" Value="36" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.section-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.section-btn.selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource Black}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

    </Window.Styles>

    <Window.Resources>
        <converters:RemoteUiItemTemplateSelector x:Key="RemoteUiItemSelector">
            <!-- Number: Slider + value -->
            <converters:RemoteUiItemTemplateSelector.NumberTemplate>
                <DataTemplate x:DataType="vm:RemoteUiItemViewModel">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="4" Margin="0,4,0,0">
                        <TextBlock Grid.Row="0" Text="{Binding Label}"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="12"
                                   IsVisible="{Binding Label, Converter={x:Static converters:IsNotNullConverter.Instance}}" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Slider Grid.Column="0"
                                    Minimum="{Binding Min}" Maximum="{Binding Max}"
                                    Value="{Binding NumericValue, Mode=TwoWay}"
                                    TickFrequency="{Binding Step}"
                                    IsSnapToTickEnabled="True"
                                    IsEnabled="{Binding IsEnabled}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding NumericValue}"
                                       Foreground="{DynamicResource PrimaryText}"
                                       VerticalAlignment="Center"
                                       Width="40"
                                       TextAlignment="Right" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </converters:RemoteUiItemTemplateSelector.NumberTemplate>
            <!-- Switch: Toggle -->
            <converters:RemoteUiItemTemplateSelector.SwitchTemplate>
                <DataTemplate x:DataType="vm:RemoteUiItemViewModel">
                    <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
                              Content="{Binding Label}"
                              IsEnabled="{Binding IsEnabled}"
                              Foreground="{DynamicResource PrimaryText}"
                              Margin="0,4,0,0" />
                </DataTemplate>
            </converters:RemoteUiItemTemplateSelector.SwitchTemplate>
            <!-- Select: ComboBox -->
            <converters:RemoteUiItemTemplateSelector.SelectTemplate>
                <DataTemplate x:DataType="vm:RemoteUiItemViewModel">
                    <StackPanel Spacing="4" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Label}"
                                   Foreground="{DynamicResource SecondaryText}" FontSize="12"
                                   IsVisible="{Binding Label, Converter={x:Static converters:IsNotNullConverter.Instance}}" />
                        <ComboBox ItemsSource="{Binding Options}"
                                  SelectedItem="{Binding StringValue, Mode=TwoWay}"
                                  IsEnabled="{Binding IsEnabled}"
                                  Background="{DynamicResource SurfaceLight}"
                                  Foreground="{DynamicResource PrimaryText}"
                                  BorderBrush="{DynamicResource AccentMuted}"
                                  CornerRadius="4"
                                  Padding="8,4" />
                    </StackPanel>
                </DataTemplate>
            </converters:RemoteUiItemTemplateSelector.SelectTemplate>
            <!-- Text: Read-only -->
            <converters:RemoteUiItemTemplateSelector.TextTemplate>
                <DataTemplate x:DataType="vm:RemoteUiItemViewModel">
                    <TextBlock Text="{Binding StringValue}"
                               Foreground="{DynamicResource PrimaryText}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </DataTemplate>
            </converters:RemoteUiItemTemplateSelector.TextTemplate>
        </converters:RemoteUiItemTemplateSelector>
    </Window.Resources>

    <Border BorderThickness="4" Background="Transparent">
        <Grid RowDefinitions="Auto, *" Background="Transparent" PointerPressed="OnMainGridPointerPressed">
            <!-- Title Bar -->
            <Border
                Grid.Row="0"
                Background="{DynamicResource Black}"
                Padding="10,8,175,8"
                PointerPressed="OnTitleBarPointerPressed">
                <TextBlock Text="{loc:Loc AppTitle}" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" FontSize="14" />
            </Border>

            <!-- Main 3-Column Layout -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto, *, Auto" Background="Transparent">

                <!-- ===== Column 0: Nav Bar ===== -->
                <Border Grid.Column="0" Width="64" Background="Transparent">
                    <Grid Background="Transparent" HorizontalAlignment="Center">
                    <!-- Top: Page nav buttons -->
                    <StackPanel Spacing="6" Margin="0,8" VerticalAlignment="Top" HorizontalAlignment="Center">
                        <Button Classes="nav-btn"
                                Classes.selected="{Binding IsControlDeskSelected}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.ControlDesk}"
                                ToolTip.Tip="{loc:Loc NavControlDesk}">
                            <i:Icon Value="fa-solid fa-sliders" FontSize="20" />
                        </Button>
                        <Button Classes="nav-btn"
                                 Classes.selected="{Binding IsConnectionsSelected}"
                                Command="{Binding SelectPageCommand}"
                                CommandParameter="{x:Static vm:NavPage.Connections}"
                                ToolTip.Tip="{loc:Loc NavConnections}">
                            <i:Icon Value="fa-solid fa-link" FontSize="20" />
                        </Button>
                    </StackPanel>

                    <!-- Bottom: Settings -->
                    <Button Classes="nav-btn"
                            Classes.selected="{Binding IsSettingsSelected}"
                            Command="{Binding SelectPageCommand}"
                            CommandParameter="{x:Static vm:NavPage.Settings}"
                            ToolTip.Tip="{loc:Loc NavSettings}"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <i:Icon Value="fa-solid fa-gear" FontSize="20" />
                    </Button>
                    </Grid>
                </Border>

                <!-- ===== Column 1: Center Content ===== -->
                <Border Grid.Column="1" Padding="16" Background="Transparent">
                    <Panel>
                        <!-- Control Desk Page -->
                        <Grid IsVisible="{Binding IsControlDeskSelected}"
                              RowDefinitions="Auto, Auto, *">

                            <!-- Row 0: Strength Controls (Channel A left, Channel B right) -->
                            <Grid Grid.Row="0" ColumnDefinitions="*, 16, *" Margin="24,0">

                                <!-- Channel A (left) -->
                                <StackPanel Grid.Column="0"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Spacing="4">
                                    <TextBlock Text="{loc:Loc ChannelA}" FontSize="14"
                                               Foreground="{DynamicResource SecondaryText}"
                                               HorizontalAlignment="Center" />
                                    <!-- Strength value with fixed-size rounded hover -->
                                    <Border Classes="strength-value-bg"
                                            PointerWheelChanged="OnChannelAWheel">
                                        <TextBlock Text="{Binding ControlDeskViewModel.StrengthA}" FontSize="56" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Max value (read-only, edit in Settings) -->
                                    <TextBlock Text="{Binding ControlDeskViewModel.MaxA, StringFormat='/ {0}'}" FontSize="13"
                                               Foreground="{DynamicResource SecondaryText}"
                                               HorizontalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                HorizontalAlignment="Center">
                                        <Border Classes="strength-btn"
                                                PointerPressed="OnChannelADecrease">
                                            <TextBlock Text="−" FontSize="18"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Border Classes="strength-btn"
                                                PointerPressed="OnChannelAIncrease">
                                            <TextBlock Text="+" FontSize="18"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Channel B (right) -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center" HorizontalAlignment="Center"
                                            Spacing="4">
                                    <TextBlock Text="{loc:Loc ChannelB}" FontSize="14"
                                               Foreground="{DynamicResource SecondaryText}"
                                               HorizontalAlignment="Center" />
                                    <!-- Strength value with fixed-size rounded hover -->
                                    <Border Classes="strength-value-bg"
                                            PointerWheelChanged="OnChannelBWheel">
                                        <TextBlock Text="{Binding ControlDeskViewModel.StrengthB}" FontSize="56" FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Max value (read-only, edit in Settings) -->
                                    <TextBlock Text="{Binding ControlDeskViewModel.MaxB, StringFormat='/ {0}'}" FontSize="13"
                                               Foreground="{DynamicResource SecondaryText}"
                                               HorizontalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                HorizontalAlignment="Center">
                                        <Border Classes="strength-btn"
                                                PointerPressed="OnChannelBDecrease">
                                            <TextBlock Text="−" FontSize="18"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Border Classes="strength-btn"
                                                PointerPressed="OnChannelBIncrease">
                                            <TextBlock Text="+" FontSize="18"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Row 1: Separator line -->
                            <Border Grid.Row="1" Height="1" Margin="0,12,0,0"
                                    Background="{DynamicResource AccentMuted}" />

                            <!-- Row 2: Bottom placeholder (layout TBD later) -->
                            <Border Grid.Row="2" Background="Transparent" />

                            <!-- Blocked overlay — covers all rows on top -->
                            <Border Grid.RowSpan="3"
                                    Background="#4D1a1a1a"
                                    IsVisible="{Binding ControlDeskViewModel.IsBlocked}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc OverriddenBy}"
                                               Foreground="White"
                                               FontSize="15"
                                               TextAlignment="Center"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding ControlDeskViewModel.ActiveRemoteName}"
                                               Foreground="#FFD700"
                                               FontSize="15"
                                               TextAlignment="Center"
                                               Cursor="Hand"
                                               PointerPressed="OnActiveRemoteNamePointerPressed" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Connections Page → info page (right column) -->
                        <Grid IsVisible="{Binding IsConnectionsSelected}"
                              ColumnDefinitions="Auto, 8, *">
                            <!-- Col 2: Info page -->
                            <Border Grid.Column="2" Background="Transparent"
                                    CornerRadius="8" Padding="16">
                                <Panel>
                                    <!-- Empty state: no card selected -->
                                    <TextBlock Text="{loc:Loc NoSourceSelected}"
                                               Foreground="{DynamicResource SecondaryText}"
                                               FontSize="14"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Opacity="0.5"
                                               IsVisible="{Binding HasNoSelectedCard}" />
                                    <!-- Detail content: card selected -->
                                    <Grid IsVisible="{Binding HasSelectedCard}"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="16">
                                        <!-- Source Name -->
                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="{loc:Loc RemoteName}"
                                                       Foreground="{DynamicResource SecondaryText}" FontSize="11"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding SelectedCard.DisplayName}"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontSize="24" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <!-- ID -->
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="{loc:Loc RemoteId}"
                                                       Foreground="{DynamicResource SecondaryText}" FontSize="11"
                                                       Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding SelectedCard.AgentId}"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <!-- Connection Status -->
                                        <StackPanel Grid.Row="2">
                                            <TextBlock Text="{loc:Loc ConnectionStatus}"
                                                       Foreground="{DynamicResource SecondaryText}" FontSize="11"
                                                       Margin="0,0,0,4" />
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Width="8" Height="8" CornerRadius="4"
                                                        Background="#00FF00"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Text="{loc:Loc ConnectionStatusConnected}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13" />
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- Toggle Button (for remotes) -->
                                        <Button Grid.Row="3" IsVisible="{Binding SelectedCard.IsRemote}"
                                                Command="{Binding ToggleActiveRemoteCommand}"
                                                CommandParameter="{Binding SelectedCard.AgentId}"
                                                HorizontalAlignment="Stretch" Height="36"
                                                CornerRadius="4"
                                                Padding="16,0"
                                                Margin="0,8,0,0">
                                            <Grid>
                                                <!-- Inactive state: Set Active -->
                                                <TextBlock Text="{loc:Loc ActionSetActive}"
                                                           IsVisible="{Binding SelectedCard.IsActiveRemote,
                                                               Converter={x:Static converters:InvertBoolConverter.Instance}}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                <!-- Active state: Set Inactive -->
                                                <TextBlock Text="{loc:Loc ActionSetInactive}"
                                                           IsVisible="{Binding SelectedCard.IsActiveRemote}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                            </Grid>
                                            <Button.Styles>
                                                <Style Selector="Button">
                                                    <Setter Property="Background"
                                                            Value="{Binding SelectedCard.IsActiveRemote,
                                                                Converter={x:Static converters:BoolToBrushConverter.Instance},
                                                                ConverterParameter='#2d2d2d;#D4AF37'}" />
                                                    <Setter Property="Foreground"
                                                            Value="{Binding SelectedCard.IsActiveRemote,
                                                                Converter={x:Static converters:BoolToBrushConverter.Instance},
                                                                ConverterParameter='#D4AF37;#1a1a1a'}" />
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                        <!-- Disconnect Button -->
                                        <Button Grid.Row="4"
                                                Content="{loc:Loc Disconnect}"
                                                Command="{Binding DisconnectAgentCommand}"
                                                CommandParameter="{Binding SelectedCard.AgentId}"
                                                HorizontalAlignment="Stretch" Height="36"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                CornerRadius="4"
                                                Padding="16,0"
                                                Margin="0,4,0,0"
                                                FontSize="13" FontWeight="SemiBold">
                                            <Button.Resources>
                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E53935" />
                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C62828" />
                                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                            </Button.Resources>
                                            <Button.Styles>
                                                <Style Selector="Button">
                                                    <Setter Property="Background" Value="{DynamicResource SurfaceLight}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentMuted}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </Style>
                                                <Style Selector="Button:pointerover">
                                                    <Setter Property="Background" Value="#E53935" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Style>
                                                <Style Selector="Button:pressed">
                                                    <Setter Property="Background" Value="#C62828" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                        <!-- Remote UI (inline, hidden when floating mode is on) -->
                                        <ScrollViewer Grid.Row="5"
                                                      IsVisible="{Binding ShowInlineRemoteUi}"
                                                      MaxHeight="300">
                                            <ItemsControl ItemsSource="{Binding SelectedCard.RemoteUiSections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="8"
                                                                BorderBrush="{DynamicResource AccentMuted}"
                                                                BorderThickness="1"
                                                                Padding="12"
                                                                Margin="0,4,0,0">
                                                            <StackPanel Spacing="8">
                                                                <!-- Group title -->
                                                                <TextBlock Text="{Binding Title}"
                                                                           IsVisible="{Binding IsGroup}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource AccentBrush}" />
                                                                <!-- Items with type-based templates -->
                                                                <ItemsControl ItemsSource="{Binding Items}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <ContentControl Content="{Binding}"
                                                                                            ContentTemplate="{StaticResource RemoteUiItemSelector}" />
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Panel>
                            </Border>
                        </Grid>

                        <!-- Settings Page -->
                        <Grid IsVisible="{Binding IsSettingsSelected}">
                            <!-- Body: section nav + content -->
                            <Grid ColumnDefinitions="160, *" Margin="20,0,20,20">
                                <!-- Left: Section Directory -->
                                <Border Grid.Column="0" Background="{DynamicResource Black}" CornerRadius="8" Padding="8">
                                    <StackPanel Spacing="4" VerticalAlignment="Top" Margin="0,4,0,0">
                                        <TextBlock Text="{loc:Loc NavSettings}" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryText}" FontWeight="SemiBold"
                                                   Margin="8,0,0,6" />
                                        <Button Content="{loc:Loc SettingsSectionGeneral}"
                                                Classes="section-btn"
                                                Click="OnGeneralSectionClick" />
                                        <Button Content="{loc:Loc SettingsSectionActuator}"
                                                Classes="section-btn"
                                                Click="OnActuatorSectionClick" />
                                        <Button Content="{loc:Loc SettingsSectionSupport}"
                                                Classes="section-btn"
                                                Click="OnSupportSectionClick" />
                                        <Button Content="{loc:Loc SettingsSectionAbout}"
                                                Classes="section-btn"
                                                Click="OnAboutSectionClick" />
                                    </StackPanel>
                                </Border>

                                <!-- Right: Heading + Section Content -->
                                <Grid Grid.Column="1" Margin="20,0,0,0">
                                    <ScrollViewer x:Name="SettingsScrollViewer" HorizontalAlignment="Stretch">
                                        <StackPanel Spacing="24">
                                            <!-- ===== General Section ===== -->
                                            <Border x:Name="GeneralSection" CornerRadius="8" Padding="8">
                                                <StackPanel Spacing="16">
                                                <!-- Section header -->
                                                <TextBlock Text="{loc:Loc SettingsSectionGeneral}" FontSize="16"
                                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                                <Separator Background="{DynamicResource AccentMuted}" Height="1" Margin="0,0,0,4" />
                                            <!-- Language -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{loc:Loc Language}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                                          SelectedItem="{Binding SelectedLanguage}"
                                                          Width="200"
                                                          Background="{DynamicResource SurfaceLight}"
                                                          Foreground="{DynamicResource PrimaryText}"
                                                          BorderBrush="{DynamicResource AccentMuted}"
                                                          CornerRadius="8"
                                                          Padding="10,5">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource PrimaryText}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <!-- Floating Remote UI -->
                                            <CheckBox IsChecked="{Binding UseFloatingRemoteUi}"
                                                      Content="{loc:Loc SettingsFloatingRemoteUi}"
                                                      Foreground="{DynamicResource PrimaryText}"
                                                      FontSize="14" />
                                            </StackPanel>
                                            </Border>

                                            <!-- ===== Actuator Section ===== -->
                                            <Border x:Name="ActuatorSection" CornerRadius="8" Padding="8">
                                                <StackPanel Spacing="16">
                                                <!-- Section header -->
                                                <TextBlock Text="{loc:Loc SettingsSectionActuator}" FontSize="16"
                                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                                <Separator Background="{DynamicResource AccentMuted}" Height="1" Margin="0,0,0,4" />
                                            <!-- Strength Limit -->
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{loc:Loc SettingsStrengthLimit}"
                                                               Foreground="{DynamicResource PrimaryText}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="0-200"
                                                               Foreground="{DynamicResource SecondaryText}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            <!-- Sync Limits -->
                                            <CheckBox IsChecked="{Binding UseActuatorLimits}"
                                                      Content="{loc:Loc SettingsUseActuatorLimits}"
                                                      ToolTip.Tip="{loc:Loc SettingsSyncLimitsTip}"
                                                      Foreground="{DynamicResource PrimaryText}"
                                                      FontSize="14" />
                                                <Grid>
                                                <Grid ColumnDefinitions="Auto, Auto">
                                                    <Grid Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                                            <!-- Channel A -->
                                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                <TextBlock Text="{loc:Loc ChannelA}" FontSize="13"
                                                                           Foreground="{DynamicResource SecondaryText}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text=":" FontSize="13"
                                                                           Foreground="{DynamicResource SecondaryText}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBox x:Name="SettingsMaxAInput"
                                                                         Text="{Binding EditMaxAValue}"
                                                                         FontSize="13"
                                                                         Width="50"
                                                                         MinHeight="0"
                                                                         Padding="4,2"
                                                                         Background="{DynamicResource SurfaceLight}"
                                                                         Foreground="{DynamicResource PrimaryText}"
                                                                         BorderBrush="{DynamicResource AccentMuted}"
                                                                         CornerRadius="4"
                                                                         LostFocus="OnMaxALostFocus"
                                                                         KeyDown="OnMaxAKeyDown" />
                                                            </StackPanel>
                                                            <!-- Channel B -->
                                                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                                <TextBlock Text="{loc:Loc ChannelB}" FontSize="13"
                                                                           Foreground="{DynamicResource SecondaryText}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBlock Text=":" FontSize="13"
                                                                           Foreground="{DynamicResource SecondaryText}"
                                                                           VerticalAlignment="Center" />
                                                                <TextBox x:Name="SettingsMaxBInput"
                                                                         Text="{Binding EditMaxBValue}"
                                                                         FontSize="13"
                                                                         Width="50"
                                                                         MinHeight="0"
                                                                         Padding="4,2"
                                                                         Background="{DynamicResource SurfaceLight}"
                                                                         Foreground="{DynamicResource PrimaryText}"
                                                                         BorderBrush="{DynamicResource AccentMuted}"
                                                                         CornerRadius="4"
                                                                         LostFocus="OnMaxBLostFocus"
                                                                         KeyDown="OnMaxBKeyDown" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Border Background="#4D1a1a1a"
                                                                IsVisible="{Binding UseActuatorLimits}" />
                                                    </Grid>
                                                    <!-- Help icon (outside overlay) -->
                                                    <Border Grid.Column="1"
                                                            Width="20" Height="20"
                                                            Background="Transparent"
                                                            CornerRadius="10"
                                                            VerticalAlignment="Center"
                                                            Margin="6,0,0,0"
                                                            ToolTip.Tip="{loc:Loc SettingsLimitRangeTip}">
                                                        <i:Icon Value="fa-solid fa-circle-question"
                                                                FontSize="14"
                                                                Foreground="{DynamicResource SecondaryText}" />
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                            </StackPanel>
                                            </StackPanel>
                                            </Border>

                                            <!-- ===== Support Section ===== -->
                                            <Border x:Name="SupportSection" CornerRadius="8" Padding="8">
                                                <StackPanel Spacing="16">
                                                <!-- Section header -->
                                                <TextBlock Text="{loc:Loc SettingsSectionSupport}" FontSize="16"
                                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                                <Separator Background="{DynamicResource AccentMuted}" Height="1" Margin="0,0,0,4" />
                                            <!-- Log -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{loc:Loc LogLabel}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <StackPanel Spacing="8">
                                                    <Button Content="{loc:Loc LogOpen}"
                                                            Width="140"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            CornerRadius="10"
                                                            Background="{DynamicResource SurfaceLight}"
                                                            Foreground="{DynamicResource PrimaryText}"
                                                            BorderBrush="{DynamicResource AccentMuted}"
                                                            Command="{Binding ShowLogWindowCommand}" />
                                                    <Button Content="{loc:Loc LogClearLogs}"
                                                            Width="140"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            CornerRadius="10"
                                                            Background="{DynamicResource SurfaceLight}"
                                                            Foreground="{DynamicResource PrimaryText}"
                                                            BorderBrush="{DynamicResource AccentMuted}"
                                                            Command="{Binding ClearLogsCommand}" />
                                                    <Button Content="{loc:Loc LogOpenDir}"
                                                            Width="140"
                                                            HorizontalContentAlignment="Center"
                                                            VerticalContentAlignment="Center"
                                                            CornerRadius="10"
                                                            Background="{DynamicResource SurfaceLight}"
                                                            Foreground="{DynamicResource PrimaryText}"
                                                            BorderBrush="{DynamicResource AccentMuted}"
                                                            Command="{Binding OpenLogDirCommand}" />
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{loc:Loc ResetStrengthLimits}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <Button Content="{loc:Loc ResetStrengthLimits}"
                                                        Command="{Binding ResetStrengthLimitsCommand}"
                                                        Width="140"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource SurfaceLight}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        BorderBrush="{DynamicResource AccentMuted}" />
                                            </StackPanel>
                                            </StackPanel>
                                            </Border>

                                        <!-- ===== About Section ===== -->
                                            <Border x:Name="AboutSection" CornerRadius="8" Padding="8">
                                                <StackPanel Spacing="16">
                                                <!-- Section header -->
                                                <TextBlock Text="{loc:Loc SettingsSectionAbout}" FontSize="16"
                                                           Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" />
                                                <Separator Background="{DynamicResource AccentMuted}" Height="1" Margin="0,0,0,4" />
                                            <!-- Version -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{loc:Loc Version}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Foreground="{DynamicResource SecondaryText}"
                                                           FontSize="13">
                                                    <TextBlock.Text>
                                                        <Binding Source="{x:Static services:LocalizationService.Instance}"
                                                                 Path="CurrentCulture"
                                                                 Converter="{x:Static converters:VersionConverter.Instance}" />
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- Disclaimer -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{loc:Loc DisclaimerTitle}"
                                                           Foreground="{DynamicResource PrimaryText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold" />
                                                <Button Content="{loc:Loc DisclaimerOpen}"
                                                        Width="140"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource SurfaceLight}"
                                                        Foreground="{DynamicResource PrimaryText}"
                                                        BorderBrush="{DynamicResource AccentMuted}"
                                                        Command="{Binding ShowDisclaimerCommand}" />
                                            </StackPanel>
                                            </StackPanel>
                                            </Border>
                                    </StackPanel>
                                </ScrollViewer>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Panel>
                </Border>

                <!-- ===== Column 2: Agent Column (global, right side) ===== -->
                <Border Grid.Column="2"
                        IsVisible="{Binding !IsSettingsSelected}"
                        Width="260"
                        Margin="8,0,16,0"
                        Background="Transparent">
                    <Grid RowDefinitions="Auto, *, Auto, Auto, Auto">
                        <!-- Row 0: Remote list title -->
                        <TextBlock Grid.Row="0" Text="{loc:Loc RemoteList}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontWeight="SemiBold" FontSize="14"
                                   Margin="4,0,0,8" />
                        <!-- Row 1: Remote list -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource Black}"
                                BorderBrush="{DynamicResource AccentMuted}"
                                BorderThickness="0,2,0,0"
                                CornerRadius="0"
                                Padding="8">
                            <Panel>
                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding RemoteCards}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource Black}"
                                                        CornerRadius="6"
                                                        Padding="12"
                                                        Margin="0,0,0,6"
                                                        BorderBrush="{DynamicResource AccentMuted}"
                                                        BorderThickness="1"
                                                        Classes.source-card="True"
                                                        PointerPressed="OnAgentCardPointerPressed"
                                                        DoubleTapped="OnAgentCardDoubleTapped">
                                                    <Border.Styles>
                                                        <Style Selector="Border.source-card:pointerover">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        </Style>
                                                    </Border.Styles>
                                                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="Auto, *, Auto">
                                                        <!-- Status dot -->
                                                        <Border Grid.Column="0" Grid.RowSpan="2"
                                                                Width="8" Height="8"
                                                                CornerRadius="4"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,0,10,0"
                                                                Background="{Binding IsActiveRemote,
                                                                    Converter={x:Static converters:BoolToBrushConverter.Instance},
                                                                    ConverterParameter='#D4AF37;#555555'}" />
                                                        <!-- Source name -->
                                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                                   Text="{Binding DisplayName}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <!-- Disconnect button -->
                                                        <Button Grid.Column="2" Grid.Row="0"
                                                                Content="×" FontSize="14"
                                                                Width="18" Height="18" Padding="0"
                                                                CornerRadius="4"
                                                                HorizontalContentAlignment="Center"
                                                                VerticalContentAlignment="Center"
                                                                Background="Transparent" BorderThickness="0"
                                                                Foreground="{DynamicResource SecondaryText}"
                                                                VerticalAlignment="Center"
                                                                ToolTip.Tip="{loc:Loc Disconnect}"
                                                                Command="{Binding DataContext.DisconnectAgentCommand, ElementName=Root}"
                                                                CommandParameter="{Binding AgentId}">
                                                            <Button.Resources>
                                                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E53935" />
                                                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C62828" />
                                                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                                            </Button.Resources>
                                                            <Button.Styles>
                                                                <Style Selector="Button:pointerover">
                                                                    <Setter Property="Background" Value="#E53935" />
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </Style>
                                                                <Style Selector="Button:pressed">
                                                                    <Setter Property="Background" Value="#C62828" />
                                                                    <Setter Property="Foreground" Value="White" />
                                                                </Style>
                                                            </Button.Styles>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <TextBlock Text="{loc:Loc NoAgent}"
                                           IsVisible="{Binding HasNoRemoteCards}"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Panel>
                        </Border>
                        <!-- Row 2: Separator -->
                        <Separator Grid.Row="2"
                                   Background="{DynamicResource AccentMuted}" Height="1" Margin="4,0,0,0" />
                        <!-- Row 3: Section title -->
                        <TextBlock Grid.Row="3"
                                   Text="{loc:Loc NavActuator}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontWeight="SemiBold" FontSize="14"
                                   Margin="8,12,0,4" />
                        <!-- Row 4: Actuator section -->
                        <Border Grid.Row="4"
                                BorderBrush="{DynamicResource AccentMuted}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Height="60"
                                Margin="4,8,4,4">
                            <Grid>
                                <!-- With actuator -->
                                <Border IsVisible="{Binding HasActuator}"
                                        Background="Transparent"
                                        CornerRadius="6"
                                        Padding="12">
                                    <Grid RowDefinitions="Auto, Auto" RowSpacing="4">
                                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ActuatorCard.DisplayName}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="2"
                                                    Content="×" FontSize="14"
                                                    Width="18" Height="18" Padding="0"
                                                    CornerRadius="4"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource SecondaryText}"
                                                    VerticalAlignment="Center"
                                                    ToolTip.Tip="{loc:Loc Disconnect}"
                                                    Command="{Binding DataContext.DisconnectAgentCommand, ElementName=Root}"
                                                    CommandParameter="{Binding ActuatorCard.AgentId}">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#E53935" />
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#C62828" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                                </Button.Resources>
                                                <Button.Styles>
                                                    <Style Selector="Button:pointerover">
                                                        <Setter Property="Background" Value="#E53935" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Style>
                                                    <Style Selector="Button:pressed">
                                                        <Setter Property="Background" Value="#C62828" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Style>
                                                </Button.Styles>
                                            </Button>
                                        </Grid>
                                        <TextBlock Grid.Row="1"
                                                   Foreground="{DynamicResource SecondaryText}"
                                                   FontSize="11"
                                                   Margin="4,0,0,0">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="A: {0} / {1}    B: {2} / {3}">
                                                    <Binding Path="ActuatorCard.StrengthA" />
                                                    <Binding Path="ActuatorCard.MaxA" />
                                                    <Binding Path="ActuatorCard.StrengthB" />
                                                    <Binding Path="ActuatorCard.MaxB" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                                <!-- No actuator: full card clickable -->
                                <Button IsVisible="{Binding !HasActuator}"
                                        Content="+" FontSize="24"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource SecondaryText}"
                                        ToolTip.Tip="{loc:Loc AddActuator}"
                                        Command="{Binding ShowQrCodeWindowCommand}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
